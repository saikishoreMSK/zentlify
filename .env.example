# ---------------------------------------------------------------------------
# Firebase Web SDK config (PUBLIC — safe to expose, used in the browser for
# reading products). Writes do NOT use these; they go through the server API.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Public site URL — used for metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://zentlify.com

# ---------------------------------------------------------------------------
# Firebase Admin SDK (SECRET — server only). From a service account JSON key
# in Firebase Console > Project Settings > Service accounts > Generate key.
# Keep the private key on ONE line with literal \n for newlines, wrapped in
# double quotes.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# NextAuth (SECRET — server only)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=your_long_random_secret
NEXTAUTH_URL=https://zentlify.com
ADMIN_USER=your_admin_username
ADMIN_PASS=your_strong_admin_password

# ---------------------------------------------------------------------------
# Cloudinary (SECRET — server only, used by the delete API)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

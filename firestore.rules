rules_version = '2';

// Zentlify Firestore security rules.
//
// SECURITY MODEL:
//  - The public site reads products directly from the browser, so reads are open.
//  - Writes are NEVER allowed from the browser. All create/update/delete go
//    through the server-side API (src/app/api/products/*), which uses the
//    Firebase Admin SDK and bypasses these rules after verifying the admin's
//    NextAuth session. Locking writes here closes the hole where anyone could
//    rewrite affiliate links or wipe the catalog using the public web config.
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Homepage promo banners — public read, server-only writes (Admin SDK).
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if false;
    }

    // Site config (e.g. editable category list) — public read, server-only writes.
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
